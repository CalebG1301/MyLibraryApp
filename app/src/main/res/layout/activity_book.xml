<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fitsSystemWindows="true"
    android:paddingTop="?attr/actionBarSize"
    tools:context=".BookActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Guideline for separating cover + buttons -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.56" />

            <!-- Book Cover -->
            <ImageView
                android:id="@+id/ivCoverBig"
                android:layout_width="180dp"
                android:layout_height="240dp"
                android:scaleType="centerCrop"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- BUTTONS (Right Panel) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCurrentlyReading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Currently Reading"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/guideline"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWantToRead"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Want To Read"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnCurrentlyReading"
                app:layout_constraintStart_toStartOf="@id/guideline"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAlreadyRead"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Already Read"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnWantToRead"
                app:layout_constraintStart_toStartOf="@id/guideline"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToFavorites"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Add To Favorites"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnAlreadyRead"
                app:layout_constraintStart_toStartOf="@id/guideline"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Delete From This List"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnAddToFavorites"
                app:layout_constraintStart_toStartOf="@id/guideline"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- LABELS -->
            <TextView
                android:id="@+id/lblBookName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book Name:"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/ivCoverBig"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/lblBookName"
                app:layout_constraintTop_toTopOf="@id/lblBookName"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/lblAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Author:"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/lblBookName"
                app:layout_constraintStart_toStartOf="@id/lblBookName" />

            <TextView
                android:id="@+id/tvMeta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/lblAuthor"
                app:layout_constraintTop_toTopOf="@id/lblAuthor"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/lblDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description:"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                app:layout_constraintStart_toStartOf="@id/lblBookName"
                app:layout_constraintTop_toBottomOf="@id/tvMeta" />

            <TextView
                android:id="@+id/tvLong"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:layout_constraintStart_toStartOf="@id/lblDescription"
                app:layout_constraintTop_toBottomOf="@id/lblDescription"
                app:layout_constraintEnd_toEndOf="parent"
                android:textColor="@android:color/black"
                android:textSize="14sp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</RelativeLayout>
